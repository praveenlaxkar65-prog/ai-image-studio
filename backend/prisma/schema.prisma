generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id    String @id @default(uuid())
  email String @unique
  role  String @default("user")
}

model Service {
  id              String @id @default(uuid())
  name            String
  baseCostCredits Int
  isActive        Boolean @default(true)
}

model Image {
  id        String   @id @default(uuid())
  userId    String
  url       String
  createdAt DateTime @default(now())
}